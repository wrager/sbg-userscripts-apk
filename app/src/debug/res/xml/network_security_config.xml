<?xml version="1.0" encoding="utf-8"?>
<!--
    Debug-only: доверять системным и пользовательским сертификатам.
    На старых эмуляторах (API 24) Let's Encrypt ISRG Root X1 отсутствует
    в системном хранилище, из-за чего fetch() из JS падает с сетевой ошибкой
    (onReceivedSslError покрывает только загрузку страниц, не fetch/XHR).
-->
<network-security-config>
    <base-config>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
